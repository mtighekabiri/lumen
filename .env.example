# WordPress REST API Integration
# --------------------------------
# 1. Set WORDPRESS_URL to your WordPress site (no trailing slash)
# 2. Go to wp-admin → Users → Profile → Application Passwords
# 3. Create a new Application Password and paste the values below

WORDPRESS_URL=https://lumen-research.com
WORDPRESS_USERNAME=your-wp-username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
